DATABASE_URL=db_url_here
GROQ_API_KEY=api_key_here

# Homepage crawler (all optional — defaults shown)
HOMEPAGE_MAX_PAGES=8
HOMEPAGE_T1_TIMEOUT=30
HOMEPAGE_T2_TIMEOUT=60
HOMEPAGE_CONCURRENT_REQUESTS=1
HOMEPAGE_CONCURRENT_REQUESTS_PER_DOMAIN=0
HOMEPAGE_DOWNLOAD_DELAY=0.5
HOMEPAGE_ROBOTS_TXT_OBEY=true
# Comma-delimited list; must not be empty
HOMEPAGE_CONTACT_KEYWORDS=contact,about,team,support,help,reach,people